{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/*",
    ".opencode/refs/shared-behaviors.md"
  ],
  "agent": {
    "definition-of-done-checker": {
      "color": "#22c55e",
      "steps": 15
    },
    "daniel-bachorski": {
      "color": "#f59e0b",
      "mode": "subagent",
      "steps": 20
    },
    "albena-sot": {
      "color": "#8b5cf6",
      "mode": "subagent",
      "steps": 25
    },
    "reactajiq-na-material": {
      "color": "#06b6d4"
    },
    "konete-ne-testvat": {
      "color": "#ec4899"
    },
    "steve-jobs-na-kristali": {
      "color": "#a3a3a3"
    },
    "refactor-suggester": {
      "color": "#f97316"
    },
    "build": {
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "task": {
          "definition-of-done-checker": "allow",
          "daniel-bachorski": "allow",
          "refactor-suggester": "allow",
          "*": "deny"
        }
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    }
  },
  "plugin": [
    "@knikolov/opencode-plugin-simple-memory",
    // "opencode-claude-auth",
    "@ex-machina/opencode-anthropic-auth@1.6.1"
  ]
}
